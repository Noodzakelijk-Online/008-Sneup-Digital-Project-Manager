{
  "name": "sneup",
  "version": "2.0.0",
  "description": "Autonomous AI-powered digital project manager for Trello v2.0 - proactive management, performance tracking, conversational AI, and accountability enforcement",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node src/index.js",
    "desktop": "electron .",
    "build:installer": "electron-builder --win nsis --x64",
    "dist:win": "npm run build:installer",
    "dev": "nodemon src/index.js",
    "migrate:workspace": "node scripts/migrate-workspace-scope.js",
    "evaluate:recommendations": "node scripts/evaluate-recommendations.js",
    "check:release-security": "node scripts/verify-release-security.js",
    "test": "jest",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "trello",
    "project-management",
    "ai",
    "automation",
    "nlp",
    "analytics",
    "team-management"
  ],
  "author": "Noodzakelijk Online",
  "license": "MIT",
  "dependencies": {
    "trello.js": "^1.2.8",
    "natural": "^8.0.1",
    "node-schedule": "^2.1.1",
    "mongoose": "^8.0.0",
    "express": "^4.18.2",
    "axios": "^1.18.0",
    "body-parser": "^1.20.6",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "openai": "^4.20.0",
    "pdfkit": "^0.19.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "online.noodzakelijk.sneup",
    "productName": "Sneup",
    "icon": "assets/sneup.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "src/**/*",
      "package.json",
      ".env.example",
      "!node_modules/natural/lib/natural/{analyzers,brill_pos_tagger,classifiers,distance,inflectors,ngrams,normalizers,phonetics,spellcheck,transliterators,trie,wordnet}/**/*",
      "!node_modules/natural/lib/natural/{tokenizers,stemmers}/aggressive_tokenizer_*.js",
      "!node_modules/{apparatus,memjs,pg,redis,stopwords-iso,sylvester,uuid,wordnet-db}/**/*",
      "!node_modules/natural/node_modules/{apparatus,memjs,pg,redis,stopwords-iso,sylvester,uuid,wordnet-db}/**/*",
      "!node_modules/natural/node_modules/{dotenv,mongoose}/**/*"
    ],
    "asar": true,
    "npmRebuild": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Sneup-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sneup"
    }
  }
}
