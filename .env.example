SNEUP_CLICKUP_TIMEOUT_MS=15000
SNEUP_CLICKUP_MAX_TEAMS=5
SNEUP_CLICKUP_MAX_TASKS_PER_TEAM=1000
SNEUP_CLICKUP_MAX_TOTAL_TASKS=2500
SNEUP_CLICKUP_CURSOR_LOOKBACK_MS=60000
SNEUP_AZURE_DEVOPS_TIMEOUT_MS=15000
SNEUP_AZURE_DEVOPS_MAX_PROJECTS=25
SNEUP_AZURE_DEVOPS_MAX_ITEMS_PER_PROJECT=250
SNEUP_AZURE_DEVOPS_MAX_TOTAL_ITEMS=2500
SNEUP_AZURE_DEVOPS_CURSOR_LOOKBACK_MS=60000
SNEUP_WRIKE_API_URL=https://www.wrike.com/api/v4
SNEUP_WRIKE_TIMEOUT_MS=15000
