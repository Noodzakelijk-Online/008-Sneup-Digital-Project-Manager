# Sync Configuration
FULL_SYNC_CRON=0 1 * * *
INCREMENTAL_SYNC_CRON=*/15 * * * *
# Full and incremental Trello syncs process this many boards at once. Keep this low to respect provider pacing.
SNEUP_TRELLO_BOARD_SYNC_CONCURRENCY=2
# Secret-based connector accounts are never rotated automatically. This only controls the visible review deadline.
SNEUP_CONNECTOR_CREDENTIAL_ROTATION_DAYS=90
SNEUP_CONNECTOR_CREDENTIAL_ROTATION_WARNING_DAYS=14
# Freshness review only; Sneup never automatically syncs a connector because of this setting.
SNEUP_CONNECTOR_SYNC_FRESHNESS_HOURS=24
ANALYTICS_CRON=0 * * * *
BOTTLENECK_DETECTION_CRON=*/30 * * * *
SNEUP_DEPENDENCY_STALE_AFTER_DAYS=30
SNEUP_CONNECTOR_MIN_INTERVAL_MS=500
# Runs provider queues in parallel while keeping every individual provider queue serial.
SNEUP_CONNECTOR_SYNC_CONCURRENCY=3
SNEUP_CONNECTOR_SYNC_MAX_RETRIES=2
SNEUP_CONNECTOR_SYNC_RETRY_BASE_MS=500
SNEUP_CONNECTOR_SYNC_RETRY_MAX_MS=15000
# Limits each database bulk upsert while graph projection remains ordered.
SNEUP_WORK_SIGNAL_UPSERT_BATCH_SIZE=100
SNEUP_CONNECTOR_RATE_LIMIT_MAX_PROVIDERS=250
SNEUP_GITHUB_TIMEOUT_MS=15000
SNEUP_GITHUB_MAX_REPOSITORIES=20
SNEUP_GITHUB_MAX_ITEMS_PER_REPOSITORY=200
