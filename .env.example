HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=

# Team Management
WORKLOAD_THRESHOLD_LIGHT=0.3
WORKLOAD_THRESHOLD_NORMAL=0.7
WORKLOAD_THRESHOLD_HEAVY=0.9
WORKLOAD_THRESHOLD_OVERLOADED=1.0

# Analytics
BOTTLENECK_MULTIPLIER=2.0
SEVERE_BOTTLENECK_MULTIPLIER=3.0

# ===== SNEUP V2.0 FEATURES =====

# OpenAI API (for Conversational AI)
OPENAI_API_KEY=your_openai_api_key_here

# Intervention Settings
INTERVENTION_CRON=*/30 * * * *
FOLLOWUP_CRON=0 * * * *
ESCALATION_CRON=0 */2 * * *

# Notification Delivery
# Active policies are the workspace's standing consent to send matching alerts.
# Email policies use the same Resend account as invitations, but require an explicit verified sender.
SNEUP_NOTIFICATION_EMAIL_FROM=
SNEUP_NOTIFICATION_CRON=*/15 * * * *
SNEUP_NOTIFICATION_TIMEOUT_MS=10000

# Performance Tracking
DAILY_PERFORMANCE_CRON=0 0 * * *
WEEKLY_PERFORMANCE_CRON=0 1 * * 1
MONTHLY_PERFORMANCE_CRON=0 2 1 * *
