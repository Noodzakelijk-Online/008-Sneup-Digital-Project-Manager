SNEUP_SMARTSHEET_API_URL=https://api.smartsheet.com/2.0
SNEUP_SMARTSHEET_TIMEOUT_MS=15000
SNEUP_SMARTSHEET_MAX_SHEETS=25
SNEUP_SMARTSHEET_MAX_ROWS_PER_SHEET=250
SNEUP_SMARTSHEET_MAX_TOTAL_ROWS=2500
SNEUP_SMARTSHEET_MAX_COLUMNS=12
SNEUP_SMARTSHEET_PAGE_SIZE=100
SNEUP_SMARTSHEET_CURSOR_LOOKBACK_MS=60000
SNEUP_AIRTABLE_API_URL=https://api.airtable.com/v0
SNEUP_AIRTABLE_TIMEOUT_MS=15000
SNEUP_AIRTABLE_MAX_RECORDS=1000
SNEUP_AIRTABLE_PAGE_SIZE=100
SNEUP_TODOIST_TIMEOUT_MS=15000
