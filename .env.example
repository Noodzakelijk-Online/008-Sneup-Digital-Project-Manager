# Trello API Credentials
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sneup

# Server Configuration
PORT=3000
NODE_ENV=development

# Webhook Configuration
WEBHOOK_CALLBACK_URL=https://your-domain.com/api/webhooks/trello

# Sync Configuration
FULL_SYNC_CRON=0 1 * * *
INCREMENTAL_SYNC_CRON=*/15 * * * *
ANALYTICS_CRON=0 * * * *
BOTTLENECK_DETECTION_CRON=*/30 * * * *

# Logging
LOG_LEVEL=info
LOG_FILE=logs/sneup.log

# AI/NLP Configuration
SENTIMENT_THRESHOLD=0.5
KEYWORD_EXTRACTION_LIMIT=10
RELATIONSHIP_STRENGTH_THRESHOLD=0.5

# Team Management
WORKLOAD_THRESHOLD_LIGHT=0.3
WORKLOAD_THRESHOLD_NORMAL=0.7
WORKLOAD_THRESHOLD_HEAVY=0.9
WORKLOAD_THRESHOLD_OVERLOADED=1.0

# Analytics
BOTTLENECK_MULTIPLIER=2.0
SEVERE_BOTTLENECK_MULTIPLIER=3.0

# ===== SNEUP V2.0 FEATURES =====

# OpenAI API (for Conversational AI)
OPENAI_API_KEY=your_openai_api_key_here

# Intervention Settings
INTERVENTION_CRON=*/30 * * * *
FOLLOWUP_CRON=0 * * * *
ESCALATION_CRON=0 */2 * * *

# Performance Tracking
DAILY_PERFORMANCE_CRON=0 0 * * *
WEEKLY_PERFORMANCE_CRON=0 1 * * 1
MONTHLY_PERFORMANCE_CRON=0 2 1 * *
