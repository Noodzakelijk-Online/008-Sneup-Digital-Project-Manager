# Team Management
WORKLOAD_THRESHOLD_LIGHT=0.3
WORKLOAD_THRESHOLD_NORMAL=0.7
WORKLOAD_THRESHOLD_HEAVY=0.9
WORKLOAD_THRESHOLD_OVERLOADED=1.0

# Analytics
BOTTLENECK_MULTIPLIER=2.0
SEVERE_BOTTLENECK_MULTIPLIER=3.0

# ===== SNEUP V2.0 FEATURES =====

# OpenAI API (for Conversational AI)
OPENAI_API_KEY=your_openai_api_key_here

# Intervention Settings
INTERVENTION_CRON=*/30 * * * *
FOLLOWUP_CRON=0 * * * *
ESCALATION_CRON=0 */2 * * *
# Rechecks completed actions against existing synced state only; this worker never creates a provider write.
OUTCOME_EVALUATION_CRON=30 */3 * * *
SNEUP_OUTCOME_RECHECK_DELAY_HOURS=24
SNEUP_OUTCOME_RECHECK_LIMIT=100

# Notification Delivery
# Active policies are the workspace's standing consent to send matching alerts.
# Email policies use the same Resend account as invitations, but require an explicit verified sender.
SNEUP_NOTIFICATION_EMAIL_FROM=
SNEUP_NOTIFICATION_CRON=*/15 * * * *
SNEUP_NOTIFICATION_TIMEOUT_MS=10000
SNEUP_REPORT_DELIVERY_CRON=*/15 * * * *
# The daily brief scheduler falls back to SNEUP_REPORT_DELIVERY_CRON when unset.
SNEUP_DAILY_BRIEF_DELIVERY_CRON=*/15 * * * *
# Deliver a missed weekly report once when the worker resumes within this many hours.
SNEUP_REPORT_CATCH_UP_HOURS=24

# Identity retention: terminal invitations retain lifecycle evidence but redact personal data and token material.
SNEUP_INVITE_RETENTION_DAYS=90
SNEUP_INVITE_RETENTION_BATCH_SIZE=100
SNEUP_INVITE_RETENTION_CRON=15 3 * * *

# Performance Tracking
DAILY_PERFORMANCE_CRON=0 0 * * *
WEEKLY_PERFORMANCE_CRON=0 1 * * 1
MONTHLY_PERFORMANCE_CRON=0 2 1 * *
