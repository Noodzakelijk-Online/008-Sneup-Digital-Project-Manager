SNEUP_SHORTCUT_TIMEOUT_MS=15000
SNEUP_SHORTCUT_MAX_PROJECTS=25
SNEUP_SHORTCUT_MAX_STORIES_PER_PROJECT=250
SNEUP_SHORTCUT_MAX_TOTAL_STORIES=2500
SNEUP_SHORTCUT_CURSOR_LOOKBACK_MS=60000
SNEUP_BITBUCKET_TIMEOUT_MS=15000
SNEUP_BITBUCKET_MAX_REPOSITORIES=20
SNEUP_BITBUCKET_MAX_ITEMS_PER_REPOSITORY=200
SNEUP_BITBUCKET_MAX_TOTAL_ITEMS=1000
SNEUP_BITBUCKET_PAGE_SIZE=100
SNEUP_BITBUCKET_CURSOR_LOOKBACK_MS=60000
SNEUP_HARVEST_TIMEOUT_MS=15000
SNEUP_HARVEST_MAX_ENTRIES=2000
SNEUP_HARVEST_PAGE_SIZE=250
SNEUP_HARVEST_INITIAL_LOOKBACK_DAYS=90
SNEUP_HARVEST_CURSOR_LOOKBACK_MS=60000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/sneup.log

# AI/NLP Configuration
SENTIMENT_THRESHOLD=0.5
KEYWORD_EXTRACTION_LIMIT=10
RELATIONSHIP_STRENGTH_THRESHOLD=0.5
RELATIONSHIP_ANALYSIS_LIMIT=750

# Connector Security
# Required before Sneup will store account tokens or start OAuth flows.
# Use unique 32+ character random values in every environment.
CONNECTOR_ENCRYPTION_KEY=replace_with_32_plus_random_characters
CONNECTOR_STATE_SECRET=replace_with_32_plus_random_characters
SNEUP_PUBLIC_URL=http://localhost:3000
SNEUP_TRUST_REQUEST_HOST=false

# OAuth Connector Apps (set only for providers you want to enable)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
