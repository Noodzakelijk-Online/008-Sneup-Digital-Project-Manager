# Logging
LOG_LEVEL=info
LOG_FILE=logs/sneup.log

# AI/NLP Configuration
SENTIMENT_THRESHOLD=0.5
KEYWORD_EXTRACTION_LIMIT=10
RELATIONSHIP_STRENGTH_THRESHOLD=0.5
RELATIONSHIP_ANALYSIS_LIMIT=750

# Connector Security
# Required before Sneup will store account tokens or start OAuth flows.
# Use unique 32+ character random values in every environment.
CONNECTOR_ENCRYPTION_KEY=replace_with_32_plus_random_characters
CONNECTOR_STATE_SECRET=replace_with_32_plus_random_characters
SNEUP_PUBLIC_URL=http://localhost:3000
SNEUP_TRUST_REQUEST_HOST=false

