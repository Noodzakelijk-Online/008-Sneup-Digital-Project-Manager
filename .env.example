# Trello API Credentials
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sneup

# Server Configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
SNEUP_API_KEY=replace_with_32_plus_random_characters_for_remote_api_access
SNEUP_REQUIRE_API_KEY=false
SNEUP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SNEUP_JSON_LIMIT=1mb
SNEUP_FORM_LIMIT=256kb
SNEUP_RATE_LIMIT_WINDOW_MS=60000
SNEUP_RATE_LIMIT_MAX=600
SNEUP_DEFAULT_WORKSPACE_ID=default
SNEUP_DEFAULT_WORKSPACE_NAME=Sneup Local Workspace
# Bounds concurrent MongoDB collection work during startup and manual workspace migrations.
SNEUP_WORKSPACE_BACKFILL_CONCURRENCY=4
SNEUP_SERVICE_ACTOR=sneup-api-service
SNEUP_LOCAL_ACTOR=local-user
SNEUP_LOCAL_ACTOR_NAME=Local Sneup user
SNEUP_API_TOKEN_PEPPER=replace_with_32_plus_random_characters_for_database_api_token_hashing
SNEUP_SESSION_TOKEN_PEPPER=replace_with_32_plus_random_characters_for_database_session_token_hashing
SNEUP_INVITE_TOKEN_PEPPER=replace_with_a_unique_32_plus_random_character_invitation_hashing_secret
# Invitation email is always an explicit identity-admin action. Leave unset for manual secure links only.
SNEUP_INVITE_FROM=
SNEUP_INVITE_PRODUCT_NAME=Sneup
RESEND_API_KEY=
# Webhook Configuration
WEBHOOK_CALLBACK_URL=https://your-domain.com/api/webhooks/trello
TRELLO_WEBHOOK_SECRET=your_trello_webhook_secret_here

# Sync Configuration
FULL_SYNC_CRON=0 1 * * *
INCREMENTAL_SYNC_CRON=*/15 * * * *
ANALYTICS_CRON=0 * * * *
BOTTLENECK_DETECTION_CRON=*/30 * * * *
SNEUP_DEPENDENCY_STALE_AFTER_DAYS=30
SNEUP_CONNECTOR_MIN_INTERVAL_MS=500
SNEUP_CONNECTOR_SYNC_MAX_RETRIES=2
SNEUP_CONNECTOR_SYNC_RETRY_BASE_MS=500
SNEUP_CONNECTOR_SYNC_RETRY_MAX_MS=15000
SNEUP_CONNECTOR_RATE_LIMIT_MAX_PROVIDERS=250
SNEUP_GITHUB_TIMEOUT_MS=15000
SNEUP_GITHUB_MAX_REPOSITORIES=20
SNEUP_GITHUB_MAX_ITEMS_PER_REPOSITORY=200
SNEUP_GITHUB_MAX_TOTAL_ITEMS=1000
SNEUP_GITHUB_CURSOR_LOOKBACK_MS=60000
SNEUP_TRELLO_TIMEOUT_MS=15000
SNEUP_TRELLO_MAX_BOARDS=25
SNEUP_TRELLO_MAX_CARDS_PER_BOARD=250
SNEUP_TRELLO_MAX_TOTAL_CARDS=2500
SNEUP_TRELLO_CURSOR_LOOKBACK_MS=60000
SNEUP_JIRA_TIMEOUT_MS=15000
SNEUP_JIRA_MAX_ISSUES=1000
SNEUP_JIRA_PAGE_SIZE=100
SNEUP_JIRA_CURSOR_LOOKBACK_MS=60000
SNEUP_ASANA_TIMEOUT_MS=15000
SNEUP_ASANA_MAX_PROJECTS=25
SNEUP_ASANA_MAX_TASKS_PER_PROJECT=250
SNEUP_ASANA_MAX_TOTAL_TASKS=2500
SNEUP_ASANA_CURSOR_LOOKBACK_MS=60000
SNEUP_SLACK_TIMEOUT_MS=15000
SNEUP_SLACK_MAX_CHANNELS=25
SNEUP_SLACK_MAX_MESSAGES_PER_CHANNEL=15
SNEUP_SLACK_MAX_TOTAL_MESSAGES=250
SNEUP_SLACK_CURSOR_LOOKBACK_MS=60000
SNEUP_GOOGLE_TIMEOUT_MS=15000
SNEUP_GOOGLE_MAX_CALENDARS=10
SNEUP_GOOGLE_MAX_EVENTS_PER_CALENDAR=100
SNEUP_GOOGLE_MAX_FILES=250
SNEUP_GOOGLE_CURSOR_LOOKBACK_MS=60000
SNEUP_MICROSOFT_GRAPH_API_URL=https://graph.microsoft.com/v1.0
SNEUP_MICROSOFT_TIMEOUT_MS=15000
SNEUP_MICROSOFT_MAX_EVENTS=250
SNEUP_MICROSOFT_MAX_TASK_LISTS=25
SNEUP_MICROSOFT_MAX_TASKS_PER_LIST=100
SNEUP_MICROSOFT_MAX_TOTAL_TASKS=1000
SNEUP_MICROSOFT_MAX_FILES=250
SNEUP_MICROSOFT_CURSOR_LOOKBACK_MS=60000
SNEUP_LINEAR_GRAPHQL_URL=https://api.linear.app/graphql
SNEUP_LINEAR_TIMEOUT_MS=15000
SNEUP_LINEAR_MAX_ISSUES=1000
SNEUP_LINEAR_PAGE_SIZE=100
SNEUP_LINEAR_CURSOR_LOOKBACK_MS=60000
SNEUP_NOTION_API_URL=https://api.notion.com/v1
SNEUP_NOTION_VERSION=2026-03-11
SNEUP_NOTION_TIMEOUT_MS=15000
SNEUP_NOTION_MAX_RESULTS=500
SNEUP_NOTION_PAGE_SIZE=100
SNEUP_NOTION_CURSOR_LOOKBACK_MS=60000
