# Trello API Credentials
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sneup

# Server Configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
SNEUP_API_KEY=replace_with_32_plus_random_characters_for_remote_api_access
SNEUP_REQUIRE_API_KEY=false
SNEUP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SNEUP_JSON_LIMIT=1mb
SNEUP_FORM_LIMIT=256kb
SNEUP_RATE_LIMIT_WINDOW_MS=60000
SNEUP_RATE_LIMIT_MAX=600
# Caps in-memory rate-limit cardinality; pruning removes expired buckets first, then least-recently-used buckets.
SNEUP_RATE_LIMIT_MAX_BUCKETS=10000
SNEUP_RATE_LIMIT_PRUNE_SLACK=2500
SNEUP_DEFAULT_WORKSPACE_ID=default
SNEUP_DEFAULT_WORKSPACE_NAME=Sneup Local Workspace
# Bounds concurrent MongoDB collection work during startup and manual workspace migrations.
SNEUP_WORKSPACE_BACKFILL_CONCURRENCY=4
SNEUP_SERVICE_ACTOR=sneup-api-service
SNEUP_LOCAL_ACTOR=local-user
SNEUP_LOCAL_ACTOR_NAME=Local Sneup user
SNEUP_API_TOKEN_PEPPER=replace_with_32_plus_random_characters_for_database_api_token_hashing
SNEUP_SESSION_TOKEN_PEPPER=replace_with_32_plus_random_characters_for_database_session_token_hashing
SNEUP_INVITE_TOKEN_PEPPER=replace_with_a_unique_32_plus_random_character_invitation_hashing_secret
# In a live production workspace, all three peppers above are mandatory, unique, and at least 32 characters.
# Demo mode is intentionally exempt because it does not persist live account, session, or invitation records.
# Invitation email is always an explicit identity-admin action. Leave unset for manual secure links only.
# In production, SNEUP_PUBLIC_URL must be an explicit non-local HTTPS URL without credentials, query parameters, or fragments.
SNEUP_PUBLIC_URL=http://localhost:3000
SNEUP_INVITE_FROM=
SNEUP_INVITE_PRODUCT_NAME=Sneup
RESEND_API_KEY=
# Webhook Configuration
WEBHOOK_CALLBACK_URL=https://your-domain.com/api/webhooks/trello
TRELLO_WEBHOOK_SECRET=your_trello_webhook_secret_here
SNEUP_GENERIC_WEBHOOK_MAX_BODY_BYTES=32768
# Provider retries can include x-sneup-delivery-id. Sneup stores no payload in the receipt.
SNEUP_GENERIC_WEBHOOK_DELIVERY_LEASE_MS=120000
SNEUP_GENERIC_WEBHOOK_DELIVERY_RETENTION_DAYS=14
SNEUP_SCORO_TIMEOUT_MS=15000
SNEUP_SCORO_MAX_PROJECTS=250
SNEUP_SCORO_MAX_TASKS=1000
SNEUP_SCORO_PAGE_SIZE=100
SNEUP_SCORO_MAX_RESPONSE_BYTES=1000000
SNEUP_SCORO_CURSOR_LOOKBACK_MS=60000
SNEUP_PLANE_TIMEOUT_MS=15000
SNEUP_PLANE_MAX_PROJECTS=20
SNEUP_PLANE_MAX_WORK_ITEMS=2500
SNEUP_PLANE_PAGE_SIZE=100
SNEUP_PLANE_MAX_RESPONSE_BYTES=1000000
SNEUP_PLANE_CURSOR_LOOKBACK_MS=60000
SNEUP_OPENPROJECT_TIMEOUT_MS=15000
SNEUP_OPENPROJECT_MAX_PROJECTS=100
