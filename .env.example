# Trello API Credentials
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_API_TOKEN=your_trello_api_token_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sneup

# Server Configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
SNEUP_API_KEY=replace_with_32_plus_random_characters_for_remote_api_access
SNEUP_REQUIRE_API_KEY=false
SNEUP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SNEUP_JSON_LIMIT=1mb
SNEUP_FORM_LIMIT=256kb
SNEUP_RATE_LIMIT_WINDOW_MS=60000
SNEUP_RATE_LIMIT_MAX=600
SNEUP_DEFAULT_WORKSPACE_ID=default
SNEUP_DEFAULT_WORKSPACE_NAME=Sneup Local Workspace
SNEUP_SERVICE_ACTOR=sneup-api-service
SNEUP_LOCAL_ACTOR=local-user
SNEUP_LOCAL_ACTOR_NAME=Local Sneup user
SNEUP_API_TOKEN_PEPPER=replace_with_32_plus_random_characters_for_database_api_token_hashing
# Webhook Configuration
WEBHOOK_CALLBACK_URL=https://your-domain.com/api/webhooks/trello
TRELLO_WEBHOOK_SECRET=your_trello_webhook_secret_here

# Sync Configuration
FULL_SYNC_CRON=0 1 * * *
INCREMENTAL_SYNC_CRON=*/15 * * * *
ANALYTICS_CRON=0 * * * *
BOTTLENECK_DETECTION_CRON=*/30 * * * *
SNEUP_DEPENDENCY_STALE_AFTER_DAYS=30
SNEUP_CONNECTOR_MIN_INTERVAL_MS=500
SNEUP_CONNECTOR_SYNC_MAX_RETRIES=2
SNEUP_CONNECTOR_SYNC_RETRY_BASE_MS=500
SNEUP_CONNECTOR_SYNC_RETRY_MAX_MS=15000
SNEUP_CONNECTOR_RATE_LIMIT_MAX_PROVIDERS=250

# Logging
LOG_LEVEL=info
LOG_FILE=logs/sneup.log

# AI/NLP Configuration
SENTIMENT_THRESHOLD=0.5
KEYWORD_EXTRACTION_LIMIT=10
RELATIONSHIP_STRENGTH_THRESHOLD=0.5
RELATIONSHIP_ANALYSIS_LIMIT=750

# Connector Security
# Required before Sneup will store account tokens or start OAuth flows.
# Use unique 32+ character random values in every environment.
CONNECTOR_ENCRYPTION_KEY=replace_with_32_plus_random_characters
CONNECTOR_STATE_SECRET=replace_with_32_plus_random_characters
SNEUP_PUBLIC_URL=http://localhost:3000
SNEUP_TRUST_REQUEST_HOST=false

# OAuth Connector Apps (set only for providers you want to enable)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
MIRO_CLIENT_ID=
MIRO_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=

# Team Management
WORKLOAD_THRESHOLD_LIGHT=0.3
WORKLOAD_THRESHOLD_NORMAL=0.7
WORKLOAD_THRESHOLD_HEAVY=0.9
WORKLOAD_THRESHOLD_OVERLOADED=1.0

# Analytics
BOTTLENECK_MULTIPLIER=2.0
SEVERE_BOTTLENECK_MULTIPLIER=3.0

# ===== SNEUP V2.0 FEATURES =====

# OpenAI API (for Conversational AI)
OPENAI_API_KEY=your_openai_api_key_here

# Intervention Settings
INTERVENTION_CRON=*/30 * * * *
FOLLOWUP_CRON=0 * * * *
ESCALATION_CRON=0 */2 * * *

# Performance Tracking
DAILY_PERFORMANCE_CRON=0 0 * * *
WEEKLY_PERFORMANCE_CRON=0 1 * * 1
MONTHLY_PERFORMANCE_CRON=0 2 1 * *
