GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SNEUP_GITLAB_API_URL=https://gitlab.com/api/v4
SNEUP_GITLAB_TIMEOUT_MS=15000
SNEUP_GITLAB_MAX_ITEMS=1000
SNEUP_GITLAB_PAGE_SIZE=100
SNEUP_GITLAB_CURSOR_LOOKBACK_MS=60000
SNEUP_CODA_TIMEOUT_MS=15000
SNEUP_CODA_MAX_DOCUMENTS=25
SNEUP_CODA_MAX_TABLES_PER_DOCUMENT=100
SNEUP_CODA_PAGE_SIZE=100
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
